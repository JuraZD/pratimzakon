{
  "mcpServers": {
    "pratimzakon-ops": {
      "command": "toolbox",
      "args": [
        "--tools-file", "/path/to/pratimzakon/infra/mcp-toolbox/tools.yaml",
        "--port", "5000",
        "--toolset", "ops_readonly"
      ],
      "env": {
        "PGHOST": "<TVOJ_RENDER_HOST>",
        "PGPORT": "5432",
        "PGDATABASE": "pratimzakon",
        "PGUSER": "mcp_readonly",
        "PGPASSWORD": "<UNESI_LOZINKU>"
      }
    }
  }
}
